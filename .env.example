# Copy to .env. The default domain works without editing /etc/hosts.
BASE_DOMAIN=127.0.0.1.sslip.io

# Override with your own wildcard later, for example:
# BASE_DOMAIN=dev.example.com

TRAEFIK_IMAGE=traefik:v3.3
GRAFANA_IMAGE=grafana/grafana:11.5.2
PROMETHEUS_IMAGE=prom/prometheus:v3.1.0
LOKI_IMAGE=grafana/loki:3.3.2
ALLOY_IMAGE=grafana/alloy:v1.6.1
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:v0.49.2
NODE_EXPORTER_IMAGE=prom/node-exporter:v1.8.2

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
